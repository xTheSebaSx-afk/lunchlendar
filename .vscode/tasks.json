{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Start Server",
            "type": "shell",
            "command": "npm start",
            "options": {
                "cwd": "${workspaceFolder}/server"
            },
            "presentation": {
                "panel": "new",
                "group": "server",
                "reveal": "always"
            },
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Start Client",
            "type": "shell",
            "command": "npm run dev",
            "options": {
                "cwd": "${workspaceFolder}/client"
            },
            "presentation": {
                "panel": "new",
                "group": "client",
                "reveal": "always"
            },
            "problemMatcher": []
        },
        {
            "label": "Start Full Stack",
            "dependsOn": [
                "Start Server",
                "Start Client"
            ],
            "dependsOrder": "parallel",
            "problemMatcher": [],
            "runOptions": {
                "runOn": "folderOpen"
            }
        },
        {
            "label": "Subtree Split Client",
            "type": "shell",
            "command": "git subtree split --prefix=client -b front",
            "problemMatcher": [],
            "presentation": {
                "panel": "new",
                "reveal": "always",
            }
        },
        {
            "label": "Push Front Branch",
            "type": "shell",
            "command": "git push origin front",
            "problemMatcher": [],
            "presentation": {
                "panel": "new",
                "reveal": "always",
            }
        },
        {
            "label": "Deploy Client to GitHub",
            "dependsOn": [
                "Subtree Split Client",
                "Push Front Branch"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new",
            }
        }
    ]
}